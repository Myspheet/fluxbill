APP_NAME=FluxBill
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://fluxbill.app

FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=fluxbill
DB_USERNAME=fluxbill
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@fluxbill.app"
MAIL_FROM_NAME="${APP_NAME}"

# Nomba — blank until July 1; populating these + making a live call is in-window work.
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_WEBHOOK_SECRET=
NOMBA_PRIMARY_ACCOUNT_NUMBER=
NOMBA_PRIMARY_BANK_CODE=

GEMINI_API_KEY=
FLUXBILL_PARTIAL_PAYMENT_TOLERANCE=5000   # kobo

VITE_APP_NAME="${APP_NAME}"
